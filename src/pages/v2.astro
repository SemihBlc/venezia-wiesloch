---
import Layout from "../layouts/Layout.astro";
import { v } from "../data";
const fonts =
  "https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700&display=swap";
const farben = ["#ff6fb5", "#3fd9b8", "#ffd23f", "#6fb8ff"];
---

<Layout title={`${v.name} Wiesloch — Eis das glücklich macht`} fonts={fonts}>
  <main class="min-h-svh bg-[#fff7ef] text-[#3a2752] antialiased [font-family:Nunito,sans-serif]">
    <header class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <span class="round text-2xl font-bold text-[#ff4fa3]">Venezia<span class="text-[#3fd9b8]">.</span></span>
      <a href={v.telHref} class="round rounded-full bg-[#ff4fa3] px-5 py-2.5 text-sm font-bold text-white shadow-[0_6px_0_#d62e84] transition active:translate-y-0.5 active:shadow-[0_3px_0_#d62e84]">Anrufen 🍦</a>
    </header>

    <section class="relative overflow-hidden">
      <div class="absolute -top-20 -right-20 size-72 rounded-full bg-[#ffd23f]/40 blur-2xl"></div>
      <div class="absolute top-40 -left-16 size-60 rounded-full bg-[#6fb8ff]/40 blur-2xl"></div>
      <div class="relative mx-auto max-w-6xl px-6 pt-10 pb-16 text-center">
        <span class="round inline-flex items-center gap-2 rounded-full bg-[#3fd9b8]/20 px-4 py-1.5 text-sm font-bold text-[#1f9e83]">
          <span class="size-2 rounded-full bg-[#3fd9b8]"></span> Jetzt geöffnet · bis 23 Uhr
        </span>
        <h1 class="round mx-auto mt-6 max-w-3xl text-6xl leading-[0.95] font-bold sm:text-8xl">
          <span class="text-[#ff4fa3]">Eis</span> das <span class="text-[#3fd9b8]">glücklich</span> macht 🍨
        </h1>
        <p class="mx-auto mt-6 max-w-lg text-lg font-semibold text-[#6a5b7e]">
          Hausgemachtes Gelato, Spaghetti-Eis & frische Limo — bei Marcello mitten in Wiesloch.
        </p>
        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a href={v.telHref} class="round rounded-full bg-[#ff4fa3] px-8 py-4 text-lg font-bold text-white shadow-[0_8px_0_#d62e84] transition active:translate-y-1 active:shadow-[0_2px_0_#d62e84]">Jetzt anrufen</a>
          <a href={v.mapsUrl} target="_blank" rel="noopener" class="round rounded-full bg-white px-8 py-4 text-lg font-bold text-[#3a2752] shadow-[0_8px_0_#e7d9f0] transition active:translate-y-1 active:shadow-[0_2px_0_#e7d9f0]">Route 📍</a>
        </div>
        <div class="mt-7 round text-lg font-bold">⭐ {v.rating} · {v.reviews} Bewertungen</div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 py-14">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {v.spezial.map(([t, d], i) => (
          <article class="rounded-3xl p-6 text-white shadow-lg" style={`background:${farben[i % 4]}`}>
            <div class="round text-4xl">{["🍝", "🍋", "🍰", "☕"][i % 4]}</div>
            <h3 class="round mt-3 text-xl font-bold">{t}</h3>
            <p class="mt-1.5 text-sm font-semibold text-white/90">{d}</p>
          </article>
        ))}
      </div>
      <div class="mt-7 flex flex-wrap justify-center gap-2.5">
        {v.eis.map((e, i) => (
          <span class="round rounded-full px-4 py-2 text-sm font-bold text-white" style={`background:${farben[i % 4]}`}>{e}</span>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-16">
      <div class="grid gap-5 lg:grid-cols-2">
        <div class="rounded-3xl bg-[#6fb8ff]/20 p-8">
          <h2 class="round text-2xl font-bold text-[#2b7fd6]">Öffnungszeiten</h2>
          <dl class="mt-5 space-y-3">
            {v.zeiten.map(([t, z]) => (
              <div class="flex justify-between border-b border-[#3a2752]/10 pb-3 font-semibold"><dt>{t}</dt><dd class="round text-lg">{z}</dd></div>
            ))}
          </dl>
        </div>
        <div class="rounded-3xl bg-[#ff4fa3]/10 p-8">
          <h2 class="round text-2xl font-bold text-[#ff4fa3]">Komm vorbei!</h2>
          <p class="mt-4 text-lg font-semibold">{v.adresse}</p>
          <p class="mt-1 font-semibold"><a href={v.telHref} class="text-[#ff4fa3]">{v.tel}</a></p>
          <a href={v.mapsUrl} target="_blank" rel="noopener" class="round mt-6 inline-block rounded-full bg-[#3fd9b8] px-7 py-3.5 font-bold text-white shadow-[0_6px_0_#1f9e83]">Route öffnen</a>
        </div>
      </div>
      <p class="mt-10 text-center text-xs font-semibold text-[#6a5b7e]/60">Variante 2 · Hell &amp; verspielt (Gelato-Pop) · NURAC-Entwurf</p>
    </section>
  </main>
</Layout>

<style>
  .round { font-family: "Fredoka", system-ui, sans-serif; }
</style>
